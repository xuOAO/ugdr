#!/usr/bin/env python3

import argparse
import json
import sys
from pathlib import Path

from ugdr_cli.bootstrap import run_bootstrap
from ugdr_cli.build import run_build, run_smoke, run_test
from ugdr_cli.environment import run_doctor
from ugdr_cli.quality import run_format, run_lint
from ugdr_cli.result import render_human, render_json
from ugdr_cli.workflow import (
    render_workflow_human,
    run_state_core,
    state_next,
    state_show,
)


REPOSITORY_ROOT = Path(__file__).resolve().parent.parent


def create_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="tools/ugdr")
    subparsers = parser.add_subparsers(dest="command")

    doctor = subparsers.add_parser("doctor", help="Diagnose the local development environment.")
    doctor.add_argument("--json", action="store_true", dest="json_mode")

    bootstrap = subparsers.add_parser(
        "bootstrap", help="Diagnose the environment and initialize repository-local build metadata."
    )
    bootstrap.add_argument("--json", action="store_true", dest="json_mode")
    bootstrap.add_argument("--build-dir", default="build")

    format_command = subparsers.add_parser(
        "format", help="Format managed C, C++, and CUDA sources."
    )
    format_command.add_argument("--check", action="store_true", dest="check_only")
    format_command.add_argument("--json", action="store_true", dest="json_mode")

    lint = subparsers.add_parser(
        "lint", help="Run read-only formatting, static, boundary, and governance checks."
    )
    lint.add_argument("--build-dir", default="build")
    lint.add_argument("--json", action="store_true", dest="json_mode")

    for name, help_text in (
        ("build", "Configure and compile the repository with CMake and Ninja."),
        ("test", "Build the repository and run the complete CTest suite."),
        ("smoke", "Run only the minimal handoff, client, and daemon checks."),
    ):
        command = subparsers.add_parser(name, help=help_text)
        command.add_argument("--build-dir", default="build")
        command.add_argument("--json", action="store_true", dest="json_mode")

    state = subparsers.add_parser(
        "state", help="Read, decide, and update the guarded project workflow state."
    )
    state_commands = state.add_subparsers(dest="state_command", required=True)
    for name, help_text in (
        ("show", "Validate and show the current project state."),
        ("next", "Determine the next base action from stable workflow rules."),
    ):
        command = state_commands.add_parser(name, help=help_text)
        command.add_argument("--json", action="store_true", dest="json_mode")

    transition = state_commands.add_parser(
        "transition", help="Delegate a guarded same-scope transition to project_state.py."
    )
    _add_transition_arguments(transition)

    advance = state_commands.add_parser(
        "advance-scope", help="Start a user-confirmed scope after a completed scope."
    )
    _add_transition_arguments(advance, advance_scope=True)

    reconcile = state_commands.add_parser(
        "reconcile-roadmap", help="Derive current next_actions from the reviewed roadmap."
    )
    reconcile.add_argument("--updated-by", required=True, choices=("human", "agent"))
    reconcile.add_argument("--dry-run", action="store_true")
    reconcile.add_argument("--json", action="store_true", dest="json_mode")
    return parser


def _add_transition_arguments(parser: argparse.ArgumentParser, advance_scope=False) -> None:
    states = (
        "awaiting_acceptance",
        "awaiting_review",
        "blocked",
        "completed",
        "ready_for_implementation",
    )
    choices = tuple(value for value in states if not advance_scope or value != "completed")
    parser.add_argument("--to", required=True, choices=choices)
    parser.add_argument("--updated-by", required=True, choices=("human", "agent"))
    parser.add_argument("--version", required=advance_scope)
    parser.add_argument("--feature", required=advance_scope)
    parser.add_argument("--step", required=advance_scope)
    parser.add_argument("--blocker", action="append", default=[])
    parser.add_argument("--reviewed-doc", action="append", default=[])
    parser.add_argument("--verification-passed", action="store_true")
    parser.add_argument("--human-confirmed", action="store_true")
    parser.add_argument("--dry-run", action="store_true")
    parser.add_argument("--json", action="store_true", dest="json_mode")


def _state_core_arguments(args, advance_scope=False):
    values = ["--to", args.to, "--updated-by", args.updated_by]
    for name in ("version", "feature", "step"):
        value = getattr(args, name, None)
        if value is not None:
            values.extend(["--" + name.replace("_", "-"), value])
    for value in args.blocker:
        values.extend(["--blocker", value])
    for value in args.reviewed_doc:
        values.extend(["--reviewed-doc", value])
    for name in (
        "verification_passed",
        "human_confirmed",
        "dry_run",
    ):
        if getattr(args, name, False):
            values.append("--" + name.replace("_", "-"))
    return values


def _run_state_command(args):
    if args.state_command == "show":
        return state_show(REPOSITORY_ROOT)
    if args.state_command == "next":
        return state_next(REPOSITORY_ROOT)
    if args.state_command == "reconcile-roadmap":
        arguments = ["--updated-by", args.updated_by]
        if args.dry_run:
            arguments.append("--dry-run")
        return run_state_core(REPOSITORY_ROOT, args.state_command, arguments)
    return run_state_core(
        REPOSITORY_ROOT,
        args.state_command,
        _state_core_arguments(args, args.state_command == "advance-scope"),
    )


def main() -> int:
    parser = create_parser()
    args = parser.parse_args()
    if args.command is None:
        parser.print_help(sys.stderr)
        return 2

    if args.command == "state":
        payload, exit_code = _run_state_command(args)
        rendered = (
            json.dumps(payload, ensure_ascii=False, indent=2)
            if args.json_mode
            else render_workflow_human(payload)
        )
        sys.stdout.write(rendered)
        sys.stdout.write("\n")
        return exit_code
    if args.command == "doctor":
        result = run_doctor()
    elif args.command == "bootstrap":
        result = run_bootstrap(REPOSITORY_ROOT, args.build_dir)
    elif args.command == "format":
        result = run_format(REPOSITORY_ROOT, args.check_only)
    elif args.command == "lint":
        result = run_lint(REPOSITORY_ROOT, args.build_dir)
    elif args.command == "build":
        result = run_build(REPOSITORY_ROOT, args.build_dir)
    elif args.command == "test":
        result = run_test(REPOSITORY_ROOT, args.build_dir)
    else:
        result = run_smoke(REPOSITORY_ROOT, args.build_dir)

    rendered = render_json(result) if args.json_mode else render_human(result)
    sys.stdout.write(rendered)
    sys.stdout.write("\n")
    return result.exit_code


if __name__ == "__main__":
    sys.exit(main())
