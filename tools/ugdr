#!/usr/bin/env python3

import argparse
import sys
from pathlib import Path

from ugdr_cli.bootstrap import run_bootstrap
from ugdr_cli.build import run_build, run_smoke, run_test
from ugdr_cli.environment import run_doctor
from ugdr_cli.quality import run_format, run_lint
from ugdr_cli.result import render_human, render_json


REPOSITORY_ROOT = Path(__file__).resolve().parent.parent


def create_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="tools/ugdr")
    subparsers = parser.add_subparsers(dest="command")

    doctor = subparsers.add_parser("doctor", help="Diagnose the local development environment.")
    doctor.add_argument("--json", action="store_true", dest="json_mode")

    bootstrap = subparsers.add_parser(
        "bootstrap", help="Diagnose the environment and initialize repository-local build metadata."
    )
    bootstrap.add_argument("--json", action="store_true", dest="json_mode")
    bootstrap.add_argument("--build-dir", default="build")

    format_command = subparsers.add_parser(
        "format", help="Format managed C, C++, and CUDA sources."
    )
    format_command.add_argument("--check", action="store_true", dest="check_only")
    format_command.add_argument("--json", action="store_true", dest="json_mode")

    lint = subparsers.add_parser(
        "lint", help="Run read-only formatting, static, boundary, and governance checks."
    )
    lint.add_argument("--build-dir", default="build")
    lint.add_argument("--json", action="store_true", dest="json_mode")

    for name, help_text in (
        ("build", "Configure and compile the repository with CMake and Ninja."),
        ("test", "Build the repository and run the complete CTest suite."),
        ("smoke", "Run only the minimal handoff, client, and daemon checks."),
    ):
        command = subparsers.add_parser(name, help=help_text)
        command.add_argument("--build-dir", default="build")
        command.add_argument("--json", action="store_true", dest="json_mode")
    return parser


def main() -> int:
    parser = create_parser()
    args = parser.parse_args()
    if args.command is None:
        parser.print_help(sys.stderr)
        return 2

    if args.command == "doctor":
        result = run_doctor()
    elif args.command == "bootstrap":
        result = run_bootstrap(REPOSITORY_ROOT, args.build_dir)
    elif args.command == "format":
        result = run_format(REPOSITORY_ROOT, args.check_only)
    elif args.command == "lint":
        result = run_lint(REPOSITORY_ROOT, args.build_dir)
    elif args.command == "build":
        result = run_build(REPOSITORY_ROOT, args.build_dir)
    elif args.command == "test":
        result = run_test(REPOSITORY_ROOT, args.build_dir)
    else:
        result = run_smoke(REPOSITORY_ROOT, args.build_dir)

    rendered = render_json(result) if args.json_mode else render_human(result)
    sys.stdout.write(rendered)
    sys.stdout.write("\n")
    return result.exit_code


if __name__ == "__main__":
    sys.exit(main())
