{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ugdr.local/lark/account.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "account_id",
    "label",
    "identity",
    "purposes",
    "enabled"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "account_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{0,62}$"
    },
    "label": {
      "type": "string",
      "minLength": 1
    },
    "identity": {
      "enum": [
        "user",
        "bot"
      ]
    },
    "purposes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "enabled": {
      "type": "boolean"
    }
  }
}
