{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ugdr.local/schemas/project-roadmap-v1.json",
  "title": "UGDR reviewed project roadmap",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "reviewed_sources",
    "routes"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "reviewed_sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "revision",
          "body_sha256"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "revision": {
            "type": "integer",
            "minimum": 1
          },
          "body_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          }
        }
      }
    },
    "routes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "version",
          "feature",
          "step",
          "source",
          "next_actions"
        ],
        "properties": {
          "version": {
            "type": "string",
            "pattern": "^v[1-9][0-9]*$"
          },
          "feature": {
            "type": "string",
            "pattern": "^F[0-9]{2}$"
          },
          "step": {
            "type": "string",
            "pattern": "^F[0-9]{2}-S[0-9]{2}$"
          },
          "source": {
            "type": "string"
          },
          "next_actions": {
            "$ref": "current.schema.json#/$defs/next_actions"
          }
        }
      }
    }
  }
}
